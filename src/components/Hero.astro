---
import schoollogo from "../assets/logo.jpg";
import facebooklogo from "../assets/facebook.svg";
import telegramlogo from "../assets/telegram.svg";
---

<section class="hero">
  <div class="animated-background">
    <div class="pop-item item-1">🎓</div>
    <div class="pop-item item-2">📚</div>
    <div class="pop-item item-3">✏️</div>
    <div class="pop-item item-4">🌟</div>
    <div class="pop-item item-5">🎒</div>
  </div>

  <div class="hero-content">
    <img src={schoollogo.src} 
         alt="Логотип школи" 
         class="hero-logo">
    <h1>Гімназія №201 Дніпровського району м. Києва</h1>
  </div>

  <div class="social-icons">
    <a href="https://www.facebook.com/szsh201" target="_blank" aria-label="Facebook" class="social-button">
      <img src={facebooklogo.src} alt="Facebook Icon" class="social-icon-svg">
    </a>
    <a href="https://t.me/s/szch201Kyiv" target="_blank" aria-label="Telegram" class="social-button">
      <img src={telegramlogo.src} alt="Telegram Icon" class="social-icon-svg">
    </a>
    <a href="http://school201.edukit.kiev.ua" target="_blank" aria-label="School Website" class="social-button">
      <img src={schoollogo.src} alt="School Icon" class="social-icon-svg">
    </a>
  </div>
</section>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Open Sans', sans-serif;
    background: #f7f7f7;
  }

  /* Hero Section */
  .hero {
    background: rgb(75, 100, 150);
    background-size: cover;
    background-position: center;
    color: white;
    min-height: 20vh;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 40px 20px;
    position: relative; 
    flex-wrap: wrap; 
    overflow: hidden; /* CRITICAL: Prevents animations from expanding the section size */
  }

  /* --- NEW: Animation Styles --- */
  .animated-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none; /* Prevents animations from blocking clicks */
    z-index: 0; 
  }

  .pop-item {
    position: absolute;
    opacity: 0; /* Hidden by default */
    font-size: 3rem; /* Size of the emojis. Change width/height if using images */
    animation: popAndFloat linear infinite;
  }

  /* Individual timings and positions for the random effect */
  .item-1 { left: 10%; bottom: -20px; animation-duration: 7s; animation-delay: 0s; }
  .item-2 { left: 30%; bottom: -20px; animation-duration: 9s; animation-delay: 2s; }
  .item-3 { left: 60%; bottom: -20px; animation-duration: 6s; animation-delay: 4s; }
  .item-4 { left: 85%; bottom: -20px; animation-duration: 8s; animation-delay: 1s; }
  .item-5 { left: 50%; bottom: -20px; animation-duration: 10s; animation-delay: 5s; }

  @keyframes popAndFloat {
    0% {
      opacity: 0;
      transform: translateY(0) scale(0.5); /* Starts small and hidden */
    }
    15% {
      opacity: 0.4;
      transform: translateY(-20px) scale(1.2); /* Pops out slightly larger */
    }
    50% {
      opacity: 0.2;
      transform: translateY(-60px) scale(1); /* Floats up, returning to normal size */
    }
    100% {
      opacity: 0;
      transform: translateY(-120px) scale(0.8); /* Fades out as it drifts higher */
    }
  }

  /* Keep content above the background animation */
  .hero-content, .social-icons {
    position: relative;
    z-index: 1;
  }
  /* ------------------------------ */

  .hero-content {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-logo {
    max-width: 250px;
    width: 100%;
    padding-right: 5vh;
  }

  .hero h1 {
    font-family: 'Oswald', sans-serif;
    font-size: 3.5rem;
    line-height: 1.2;
    margin-bottom: 0; 
  }

  /* Social Icons Styling */
  .social-icons {
    position: absolute; 
    top: 20px; 
    right: 20px; 
    display: flex;
    gap: 15px; 
  }

  .social-button { 
    display: flex;
    align-items: center;
    justify-content: center;
    width: 45px; 
    height: 45px; 
    background-color: rgba(255, 255, 255, 0.2); 
    border-radius: 50%; 
    text-decoration: none;
    transition: background-color 0.3s ease, transform 0.2s ease;
    border: none;
    cursor: pointer;
    padding: 0; 
  }

  .social-button:hover {
    background-color: rgba(255, 255, 255, 0.4); 
    transform: scale(1.1); 
  }

  .social-icon-svg { 
    width: 100%; 
    height: 100%; 
  }

  /* Media Queries */
  @media (max-width: 768px) {
    .hero {
      min-height: 15vh;
      padding: 30px 15px;
    }
    
    .hero h1 {
      font-size: 2.5rem;
    }
    
    .hero-logo {
      max-width: 180px;
      padding-right: 3vh;
    }

    .social-icons {
      top: 15px; 
      right: 15px; 
      gap: 10px;
    }

    .social-button {
      width: 40px;
      height: 40px;
    }

    .pop-item {
      font-size: 2rem; /* Make popping items smaller on mobile */
    }
  }

  @media (max-width: 480px) {
    .hero {
      min-height: 10vh;
      padding: 20px 10px;
      flex-direction: column;
      justify-content: center;
    }

    .hero-logo {
      padding-right: 0;
      margin-bottom: 15px;
      max-width: 120px;
    }
    
    .hero h1 {
      font-size: 1.8rem;
    }

    .social-icons {
      position: static; 
      margin-top: 20px; 
      justify-content: center; 
      width: 100%; 
      gap: 15px; 
    }

    .social-button {
      width: 45px; 
      height: 45px;
    }
  }
</style>
